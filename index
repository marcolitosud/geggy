function renderDiet(){
  document.getElementById('meals').innerHTML = DIET.map((m,i)=>`
    <div class="meal" data-i="${i}">
      <div class="meal-h">
        <b>${m.name}</b>
        <span class="t">${m.slots.length} voci</span>
      </div>
      <div class="meal-b">
        ${m.slots.map((s,j)=>`
          <div class="slot">
            <label>${s.label}</label>
            ${ s.alts && s.alts.length
              ? `<select data-sel="${i}-${j}">
                   <option>${s.base}</option>
                   ${s.alts.map(a=>`<option>${a}</option>`).join('')}
                 </select>`
              : `<div class="fixed">${s.base}</div>` }
            ${ s.note ? `<div class="note-md">${s.note}</div>` : '' }
          </div>`).join('')}
      </div>
    </div>`).join('');

  document.querySelectorAll('.meal-h').forEach(h=>{
    h.onclick=()=>h.parentElement.classList.toggle('open');
  });
  // ripristina scelte
  document.querySelectorAll('[data-sel]').forEach(async sel=>{
    try{
      const r = await window.storage.get('curva:diet:'+sel.dataset.sel);
      if(r) sel.value = r.value;
    }catch{}
    sel.onchange=async()=>{
      try{ await window.storage.set('curva:diet:'+sel.dataset.sel, sel.value); }catch{}
    };
  });
}

/* ---------- nav ---------- */
function go(p){
  document.querySelectorAll('.page').forEach(s=>s.classList.toggle('on', s.id==='p-'+p));
  document.querySelectorAll('nav.tabs button').forEach(b=>b.classList.toggle('on', b.dataset.p===p));
  window.scrollTo(0,0);
}
document.querySelectorAll('nav.tabs button').forEach(b=>b.onclick=()=>go(b.dataset.p));

/* ---------- init ---------- */
